{
	"include": ["./src/**/*.ts"],

	"compilerOptions":
	{
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "node",

		"removeComments": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,

		"strict": true,
		"noImplicitAny": true,
		"alwaysStrict": true,

		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"skipLibCheck": true
	},

	"references":
	[
		{ "path": "./src/client" },
		{ "path": "./src/common" },
		{ "path": "./src/server" }
	]
}
