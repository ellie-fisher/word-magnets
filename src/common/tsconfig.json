{
	"compilerOptions":
	{
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "node",
		"resolveJsonModule": true,
		"rootDir": "./",

		"declaration": true,
		"declarationMap": true,
		"declarationDir": "../../dist/common/types/",

		"sourceMap": true,
		"outDir": "../../dist/common",

		"removeComments": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,

		"strict": true,
		"noImplicitAny": true,
		"alwaysStrict": true,

		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"skipLibCheck": true,

		"composite": true
	},

	"include": ["./**/*.ts", "./**/*.json"],

	"references": []
}
